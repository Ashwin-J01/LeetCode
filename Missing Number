class Solution {
    public int missingNumber(int[] nums) {
        HashSet<Integer> set=new HashSet<>();
        for(int i=0;i<=nums.length;i++)
            set.add(i);
        for(int x:nums){
            if(set.contains(x))
                set.remove(x);
        }
        for(int y:set)
            return y;
        return -1;
    }
}
